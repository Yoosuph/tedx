# Paystack API Keys
# Copy this file to .env and fill in your actual keys
# Get your keys from: https://dashboard.paystack.com/#/settings/developer
# 
# TEST MODE (for development/testing):
# - Public Key starts with: pk_test_
# - Secret Key starts with: sk_test_
#
# LIVE MODE (for production):
# - Public Key starts with: pk_live_
# - Secret Key starts with: sk_live_

VITE_PAYSTACK_PUBLIC_KEY=
VITE_PAYSTACK_SECRET_KEY=

# API Base URL (for future backend integration)
VITE_API_URL=http://localhost:3000/api

# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudinary Configuration
# Get the Cloud Name and API Key from: https://console.cloudinary.com/settings/api-keys
# The Upload Preset MUST be configured as Unsigned and scoped to the `tedxdutse/gallery` folder.
# See CLOUDINARY_SETUP.md for the full preset configuration (allowed formats, size limits, moderation).
# NOTE: Never add CLOUDINARY_API_SECRET as a VITE_* variable. It is configured only as a
# Supabase Edge Function secret for the cloudinary-destroy function.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_UPLOAD_PRESET=
